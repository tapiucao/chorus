# Chorus — environment variables
# Copy this file to .env and fill in the values.
# All variables are optional — defaults are shown below.

# ── LLM Provider ────────────────────────────────────────────────────────────
# API key for the provider you're using (not prefixed — passed directly to the SDK)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Model selection (litellm format: provider/model-name) ────────────────────
CHORUS_MODEL_EXTRACTION=anthropic/claude-sonnet-4-6
CHORUS_MODEL_SYNTHESIS=anthropic/claude-sonnet-4-6
CHORUS_MODEL_CRITIC=anthropic/claude-sonnet-4-6

# ── Fallbacks (comma-separated, empty = disabled) ────────────────────────────
CHORUS_MODEL_EXTRACTION_FALLBACKS=openai/gpt-4o-mini,ollama/qwen2.5-coder:3b
CHORUS_MODEL_SYNTHESIS_FALLBACKS=openai/gpt-4o,ollama/qwen2.5-coder:3b
CHORUS_MODEL_CRITIC_FALLBACKS=openai/gpt-4o,ollama/qwen2.5-coder:3b

# ── LLM temperatures ─────────────────────────────────────────────────────────
# CHORUS_LLM_TEMPERATURE_EXTRACTION=0.1
# CHORUS_LLM_TEMPERATURE_SYNTHESIS=0.5
# CHORUS_LLM_TEMPERATURE_CRITIC=0.7

# ── Timeout (seconds) — leave unset to auto-detect per provider ──────────────
# CHORUS_LLM_TIMEOUT_SECONDS=120

# ── Database ─────────────────────────────────────────────────────────────────
# CHORUS_DB_URL=sqlite:///chorus.db
# CHORUS_CHECKPOINT_DB_PATH=chorus_checkpoints.db

# ── Security — set to enable API key auth on POST /api/runs ──────────────────
# CHORUS_API_KEY=your-secret-key

# ── CORS — comma-separated allowed origins (empty = same-origin only) ─────────
# CHORUS_CORS_ORIGINS=http://localhost:3000,https://app.example.com
